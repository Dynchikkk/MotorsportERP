{
  "TrackSettings": {
    "MinRacesToCreate": 5,
    "DefaultConfirmationThreshold": 10
  },
  "TournamentSettings": {
    "MinRacesToBecomeOrganizer": 10
  },
  "SeedSettings": {
    "SeedDevelopmentData": false,
    "AdminPassword": "REQUIRED_FIELD"
  },
  "MediaFileStorageSettings": {
    "UploadsPath": "REQUIRED_FIELD",
    "UploadsRequestPath": "/uploads",
    "MaxUploadSizeBytes": 5242880,
    "PhotoAllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "PhotoAllowedContentTypes": [ "image/jpeg", "image/png", "image/webp" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "REQUIRED_FIELD"
  },
  "JwtSettings": {
    "Issuer": "MotorsportApi",
    "Audience": "MotorsportClient",
    "ExpirationHours": 2,
    "Secret": "REQUIRED_FIELD"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
